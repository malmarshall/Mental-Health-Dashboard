# Groups the mh_care_df DataFrame by 'indicator' and 'demo_group', calculating the median of 'value', 'low_ci', and 'high_ci' for each group, and stores the result in sorted_mh_care

sorted_mh_care = mh_care_df.groupby(['indicator', 'demo_group'])[['value', 'low_ci', 'high_ci']].median()
