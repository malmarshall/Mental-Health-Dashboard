# %% [markdown]
# # Pivot Table Development for Analysis

# %%
#Pivot table for response stratified by age

indicators_age_all = indicators_cdc_df[indicators_cdc_df['demo_group']=='By Age'].pivot_table(
    values=['value','low_ci','high_ci'],
    index=['year','state','response','subgroup'],
    aggfunc='median',
    margins=False
)

indicators_age_all

# %%
indicators_age_all = indicators_age_all.reset_index()
indicators_age_all

# %%
# Pivot table for response stratified by age based on True(yes) responses to indicator

indicators_age_true = indicators_true_df[indicators_true_df['demo_group'] == 'By Age'].pivot_table(
    values=['value','low_ci','high_ci'],
    index=['year','state','subgroup'],
    aggfunc='median',
    margins=False
)

indicators_age_true = indicators_age_true.reset_index()
indicators_age_true

# %%

# Get sorted list of years
years = sorted(indicators_age_true['year'].unique())

fig = go.Figure()

# Create one bar trace per year
for i, yr in enumerate(years):
    df_year = indicators_age_true[indicators_age_true['year'] == yr]
    
    # Optional: aggregate across states (mean value per subgroup)
    df_grouped = df_year.groupby('subgroup', as_index=False)['value'].mean()
    
    fig.add_trace(
        go.Bar(
            x=df_grouped['subgroup'],
            y=df_grouped['value'],
            name=str(yr),
            visible=(i == 0)
        )
    )

# Create dropdown buttons
buttons = []

for i, yr in enumerate(years):
    visibility = [False] * len(years)
    visibility[i] = True
    
    buttons.append(
        dict(
            label=str(yr),
            method="update",
            args=[
                {"visible": visibility},
                {"title": f"Average Value by Age Group — {yr}"}
            ]
        )
    )

# Update layout
fig.update_layout(
    updatemenus=[
        dict(
            active=0,
            buttons=buttons,
            x=1.15,
            y=1
        )
    ],
    title=f"Average Value by Age Group — {years[0]}",
    xaxis_title="Age Group",
    yaxis_title="Value",
    template="plotly_white"
)

fig.show()

